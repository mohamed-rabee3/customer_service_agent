# Supabase Configuration

SUPABASE_URL=https://your-project.supabase.co

SUPABASE_KEY=your-supabase-anon-key

SUPABASE_SERVICE_KEY=your-supabase-service-key



# Application Security

SECRET_KEY=your-secret-key-here-change-in-production

DEBUG=true



# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:8081



# LiveKit Configuration

# Use your LiveKit Cloud host (wss:// or https:// both work; API normalizes to https)
LIVEKIT_URL=wss://your-project.livekit.cloud

LIVEKIT_API_KEY=your-livekit-api-key

LIVEKIT_API_SECRET=your-livekit-api-secret



# Gemini voice agent — Vertex AI (recommended; uses GCP $300 trial / project billing)

GEMINI_USE_VERTEX=true

GOOGLE_CLOUD_PROJECT=your-gcp-project-id

GOOGLE_CLOUD_LOCATION=us-central1

# Path to service account JSON, or use: gcloud auth application-default login

GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Vertex Live API model (do not use AI Studio preview model names here)

GEMINI_REALTIME_MODEL=gemini-live-2.5-flash-native-audio
# Startup health check only (Vertex text model, not the Live voice model)
# GEMINI_VERTEX_HEALTHCHECK_MODEL=gemini-2.5-flash
GEMINI_VOICE=Aoede

VOICE_PIPELINE=gemini



# Optional: AI Studio API key (only if GEMINI_USE_VERTEX=false)

# GEMINI_API_KEY=your-aistudio-api-key



GROQ_API_KEY=your-groq-api-key

# Optional: defaults to llama-3.1-8b-instant (supervisor live performance + sentiment)

# GROQ_MONITORING_MODEL=llama-3.1-8b-instant

# Optional: defaults to llama-3.3-70b-versatile (text/Telegram chat agent)

# GROQ_CHAT_MODEL=llama-3.3-70b-versatile



# ElevenLabs — only used when VOICE_PIPELINE=legacy

ELEVENLABS_API_KEY=your-elevenlabs-api-key

ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

ELEVENLABS_MODEL=eleven_flash_v2_5



# Chat: auto-close session and set agent idle after N seconds without messages (default 120)
# CHAT_IDLE_TIMEOUT_SECONDS=120

# Telegram — public HTTPS URL (ngrok in dev). Webhook: {base}/v1/telegram/{agent_id}
WEBHOOK_DOMAIN=https://your-subdomain.ngrok-free.app
# TELEGRAM_WEBHOOK_BASE_URL=https://your-subdomain.ngrok-free.app/v1
# TELEGRAM_BOT_TOKEN=123456789:ABCdef...

