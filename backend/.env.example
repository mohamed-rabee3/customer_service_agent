# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Application Security
SECRET_KEY=your-secret-key-at-least-32-chars-long
DEBUG=true

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://your-ngrok-url.ngrok-free.app

# LiveKit Configuration
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# AI Services
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# OpenRouter Configuration
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Webhook Configuration (set by ngrok)
WEBHOOK_DOMAIN=https://your-ngrok-url.ngrok-free.app

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
